# Auto detect text files and normalize line endings to LF
* text=auto

# PHP files
*.php text eol=lf
*.phps text eol=lf

# HTML, CSS, JavaScript
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# SQL files
*.sql text eol=lf

# Config files
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix
*.sh text eol=lf

# Documentation
*.md diff=markdown
*.txt text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.svg binary
